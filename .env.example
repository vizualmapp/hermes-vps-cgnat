# Hermes range ses clés dans ~/.hermes/.env sur le VPS.
# Ce fichier est créé automatiquement par l'assistant : docker run -it --rm -v ~/.hermes:/opt/data nousresearch/hermes-agent:<version> setup
# Ne JAMAIS committer le vrai .env : ce fichier-ci ne contient que les noms de variables.

# Provider LLM (au moins une clé requise)
OPENROUTER_API_KEY=
